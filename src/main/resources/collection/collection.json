              "mode": "raw",
              "raw": "{\n  \"name\": \"Electrónicos\",\n  \"description\": \"Dispositivos y componentes electrónicos\"\n}"
            }
          }
        },
        {
          "name": "Update product type",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/product-types/1",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
