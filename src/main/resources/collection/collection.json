            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": 1,\n  \"productTypeId\": 1,\n  \"warehouseId\": 1,\n  \"quantity\": 8,\n  \"deliveryDate\": \"2026-05-01\",\n  \"trackingNumber\": \"ABC1234567\",\n  \"vehiclePlate\": \"DEF456\",\n  \"basePrice\": 200000.00\n}"
            }
          }
