            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": 1,\n  \"productTypeId\": 1,\n  \"warehouseId\": 1,\n  \"quantity\": 5,\n  \"deliveryDate\": \"2026-04-01\",\n  \"trackingNumber\": \"ABC1234567\",\n  \"vehiclePlate\": \"ABC123\",\n  \"basePrice\": 150000.00\n}"
            }
          }
