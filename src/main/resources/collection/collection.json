            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electrónicos Actualizado\",\n  \"description\": \"Descripción actualizada\"\n}"
            }
          }
        },
        {
          "name": "Delete product type",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/product-types/1",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        }
      ]
    },
